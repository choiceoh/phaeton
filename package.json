{
  "name": "phaeton",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "next dev",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:stop": "docker compose -f docker-compose.dev.yml down",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "dev:setup": "npm install && npm run dev:db && npm run generate:types",
    "build": "next build",
    "start": "next start",
    "deploy": "bash scripts/deploy.sh",
    "deploy:rollback": "bash scripts/deploy.sh --rollback",
    "deploy:status": "bash scripts/deploy.sh --status",
    "test:live": "bash scripts/live-test.sh",
    "test:live:dev": "bash scripts/live-test.sh --dev",
    "generate:types": "payload generate:types",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/lib-storage": "^3.1026.0",
    "@payloadcms/db-postgres": "^3.81.0",
    "@payloadcms/email-nodemailer": "^3.81.0",
    "@payloadcms/live-preview-react": "^3.81.0",
    "@payloadcms/next": "^3.81.0",
    "@payloadcms/plugin-form-builder": "^3.81.0",
    "@payloadcms/plugin-nested-docs": "^3.81.0",
    "@payloadcms/plugin-search": "^3.81.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@payloadcms/storage-s3": "^3.81.0",
    "@tremor/react": "^3.18.7",
    "autoprefixer": "^10.4.27",
    "graphql": "^16.13.2",
    "next": "^16.2.2",
    "nodemailer": "^8.0.5",
    "payload": "^3.81.0",
    "postcss": "^8.5.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
