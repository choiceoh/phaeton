# SITE_ADDRESS 환경변수로 도메인 변경 가능 (기본: phaeton.example.com)
{$SITE_ADDRESS:phaeton.example.com} {
    reverse_proxy app-blue:3000 app-green:3000 {
        # 첫 번째 정상 upstream으로 라우팅 (blue-green 전환)
        lb_policy first
        lb_try_duration 5s
        lb_try_interval 250ms

        # 액티브 헬스체크
        health_uri /api/health
        health_interval 5s
        health_timeout 3s
        health_status 200

        # 실패 시 30초간 해당 upstream 제외
        fail_duration 30s
    }
}
